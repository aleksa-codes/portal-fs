---
import Layout from "@/layouts/layout.astro"
const title = "PORTAL.FS | Multiverse Generator"
---

<Layout title={title}>
  <div class="portal-wrapper" id="portal-bg">
    <div class="portal-swirl portal-layer-1"></div>
    <div class="portal-swirl portal-layer-2"></div>
    <div class="portal-swirl portal-layer-3"></div>
    <div class="portal-swirl portal-layer-4"></div>
  </div>

  <!-- MAIN CONSOLE -->
  <main class="gadget-console" id="main-console">
    <div class="screw screw-tl"></div><div class="screw screw-tr"></div>
    <div class="screw screw-bl"></div><div class="screw screw-br"></div>

    <header>
      <h1 class="app-title">PORTAL.FS</h1>
      <p class="app-subtitle">Dimensional File Generator v1.37</p>
    </header>

    <button class="battery-btn" id="openModalBtn">
      <div class="battery-status-light" id="main-status-light"></div>
      <span id="battery-btn-text">Open Core Battery Bay</span>
    </button>

    <div class="input-group">
      <label class="input-label" for="path-input">Target Coordinates:</label>
      <div class="coordinate-screen">
        <span class="coord-prefix">DIM://</span>
        <input
          type="text"
          id="path-input"
          value="pokemon/charizard.html"
          spellcheck="false"
        />
      </div>
    </div>

    <div class="sticky-note">
      <b>Aw geez, listen...</b><br />
      You can just type a path right into the spacetime URL. Like, put <code
        >/plumbus.html</code
      > at the end of the address bar up there. Supports HTML, CSS, JS, JSON.
    </div>

    <div class="portal-btn-container">
      <button class="portal-btn" id="shootPortalBtn">Shoot Portal</button>
    </div>
  </main>

  <!-- SIMULATION UI -->
  <div class="simulation-container" id="sim-container">
    <div class="loading-text" id="loading-text">SYNTHESIZING MATTER...</div>
  </div>

  <!-- BATTERY BAY MODAL -->
  <div class="modal-overlay" id="battery-modal">
    <div class="battery-bay">
      <div class="bay-header">
        <h2 class="bay-title">CORE BATTERY BAY</h2>
        <button class="close-btn" id="closeModalBtn">X</button>
      </div>

      <div class="battery-slots-container">
        {
          ["openai", "gemini", "claude"].map((provider) => (
            <div
              class={`battery-slot slot-${provider}`}
              id={`slot-${provider}`}
            >
              <div class="slot-info">
                <div class="slot-provider" style="text-transform: capitalize">
                  {provider}
                </div>
                <div class="slot-model">
                  {provider === "openai"
                    ? "gpt-5.4-nano"
                    : provider === "gemini"
                      ? "gemini-3.1-flash-lite"
                      : "claude-4.5-haiku"}
                </div>
              </div>
              <input
                type="password"
                class="slot-input"
                id={`key-${provider}`}
                placeholder="Enter Key..."
              />
              <div class="slot-actions">
                <button class="route-btn" data-provider={provider}>
                  ROUTE
                </button>
                <button class="slot-btn" data-provider={provider}>
                  SLAM
                </button>
              </div>
            </div>
          ))
        }
      </div>

      <div class="rick-note">
        <b>Look at me, Morty!</b> Read the duct tape.<br />
        I'm not sending your precious API keys to the Galactic Federation. They stay
        right here securely on the server via HTTP-only cookies and are piped straight
        to the LLMs. Stop whining about security and route the power!
      </div>
    </div>
  </div>

  <!-- GitHub Link Floater -->
  <a
    href="https://github.com/aleksa-codes/portal-fs"
    target="_blank"
    rel="noopener noreferrer"
    class="github-floater"
    title="Source Code Dimension"
  >
    <svg viewBox="0 0 24 24">
      <path
        d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
      ></path>
    </svg>
  </a>

  <script>
    interface AuthState {
      active: string | null
      keys: Record<string, string>
    }
    let authState: AuthState = { active: null, keys: {} }

    // Initialize API Keys from Backend
    document.addEventListener("DOMContentLoaded", async () => {
      try {
        const res = await fetch("/api/auth")
        authState = await res.json()
        renderUI()
      } catch (err) {
        console.error(err)
      }
    })

    // Render the states of the cores based on Auth
    function renderUI() {
      ;["openai", "gemini", "claude"].forEach((provider) => {
        const slot = document.getElementById(`slot-${provider}`)
        const input = document.getElementById(
          `key-${provider}`
        ) as HTMLInputElement
        const slamBtn = document.querySelector(
          `.slot-btn[data-provider="${provider}"]`
        ) as HTMLButtonElement
        const routeBtn = document.querySelector(
          `.route-btn[data-provider="${provider}"]`
        ) as HTMLButtonElement

        if (authState.keys[provider]) {
          slot?.classList.add("inserted")
          input.value = "••••••••••••••••••••"
          input.disabled = true
          slamBtn.innerText = "LOCKED"
          slamBtn.classList.add("eject-mode")
          routeBtn.style.display = "block"

          slamBtn.onmouseenter = () => (slamBtn.innerText = "EJECT")
          slamBtn.onmouseleave = () => (slamBtn.innerText = "LOCKED")
        } else {
          slot?.classList.remove("inserted")
          input.value = ""
          input.disabled = false
          slamBtn.innerText = "SLAM"
          slamBtn.classList.remove("eject-mode")
          routeBtn.style.display = "none"
          slamBtn.onmouseenter = null
          slamBtn.onmouseleave = null
        }

        if (authState.active === provider) {
          slot?.classList.add("routed")
          routeBtn.innerText = "[⚡ ACTIVE]"
        } else {
          slot?.classList.remove("routed")
          routeBtn.innerText = "ROUTE"
        }
      })

      const statusLight = document.getElementById("main-status-light")
      const btnText = document.getElementById("battery-btn-text")
      if (authState.active) {
        statusLight!.style.background = "#94f549"
        statusLight!.style.boxShadow =
          "0 0 15px #94f549, inset 0 0 5px rgba(0,0,0,0.5)"
        btnText!.innerText = `Power Routed: ${authState.active.toUpperCase()}`
      } else {
        statusLight!.style.background = "#ff2a2a"
        statusLight!.style.boxShadow = "inset 0 0 5px rgba(0,0,0,0.5)"
        btnText!.innerText =
          Object.keys(authState.keys).length > 0
            ? "Warning: Power Not Routed!"
            : "Open Core Battery Bay"
      }
    }

    async function saveAuth() {
      await fetch("/api/auth", {
        method: "POST",
        body: JSON.stringify(authState),
      })
      renderUI()
    }

    // Event Listeners for UI interaction
    document.querySelectorAll(".slot-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const provider = (e.target as HTMLElement).getAttribute(
          "data-provider"
        )!
        if (authState.keys[provider]) {
          // Eject
          delete authState.keys[provider]
          if (authState.active === provider)
            authState.active = Object.keys(authState.keys)[0] || null
          saveAuth()
        } else {
          // Slam
          const val = (
            document.getElementById(`key-${provider}`) as HTMLInputElement
          ).value
          if (!val) return alert("You gotta put a key in the slot, Morty!")
          authState.keys[provider] = val
          if (!authState.active) authState.active = provider
          saveAuth()
        }
      })
    })

    document.querySelectorAll(".route-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const provider = (e.target as HTMLElement).getAttribute(
          "data-provider"
        )!
        authState.active = provider
        saveAuth()
      })
    })

    // Modal Logic
    document.getElementById("openModalBtn")?.addEventListener("click", () => {
      document.getElementById("battery-modal")?.classList.add("active")
      document.getElementById("main-console")!.style.filter = "blur(3px)"
    })
    document.getElementById("closeModalBtn")?.addEventListener("click", () => {
      document.getElementById("battery-modal")?.classList.remove("active")
      document.getElementById("main-console")!.style.filter = "none"
    })

    // Simulation & Nav
    document.getElementById("shootPortalBtn")?.addEventListener("click", () => {
      if (!authState.active) {
        alert(
          "The gun has no active power! Slam an API core in the battery bay!"
        )
        return document.getElementById("openModalBtn")?.click()
      }
      let path = (document.getElementById("path-input") as HTMLInputElement)
        .value
      if (!path.startsWith("/")) path = `/${path}`

      // Play the animation natively on the current index page
      document.getElementById("main-console")?.classList.add("hidden-down")
      document.getElementById("portal-bg")?.classList.add("active-portal")
      setTimeout(() => {
        document.getElementById("sim-container")?.classList.add("active")
      }, 500)

      const text = document.getElementById("loading-text")
      if (text) {
        setTimeout(() => (text.innerText = "EXTRACTING HTML..."), 1000)
        setTimeout(
          () =>
            (text.innerText = `ROUTING THROUGH ${authState.active?.toUpperCase()}...`),
          2000
        )
        setTimeout(() => (text.innerText = "DODGING CRONENBERGS..."), 3000)
      }

      // Delay navigation so the transition can visibly play out
      setTimeout(() => {
        window.location.href = path
      }, 3500)
    })
  </script>
</Layout>
